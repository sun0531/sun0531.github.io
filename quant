        this.classList.add('active');
        const page = this.dataset.tab;
        document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
        const target = document.getElementById('page' + page.charAt(0).toUpperCase() + page.slice(1));
        if (target) target.style.display = 'block';
        if (page === 'stats') updateStats();
        if (page === 'track') renderTrackList();
        if (page === 'results') renderResults();
        if (page === 'learn') renderLearnPanel();
        document.getElementById('statsSummary').style.display = (page === 'matches' || page === 'track') ? 'grid' : 'none';
    });
});

function renderResults() {
    const el = document.getElementById('resultsList');
    const finished = trackedBets.filter(t => t.result !== 'pending');
    if (finished.length === 0) {
        el.innerHTML = '<div class="empty">📭 暂无完赛记录</div>';
        return;
    }
    let html = '';
    for (const t of finished) {
        const correct = (t.direction === '主胜' && t.result === 'home') ||
                       (t.direction === '客胜' && t.result === 'away') ||
                       (t.direction === '平局' && t.result === 'draw');
        const time = new Date(t.time).toLocaleString('zh-CN', {month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});
        html += `
        <div class="match-card" style="border-left-color:${correct ? '#4caf50' : '#f44336'};">
            <div class="top"><span>${t.league}</span><span>${time}</span></div>
            <div class="teams">${t.home} <span class="vs">vs</span> ${t.away}</div>
            <div class="pred" style="background:#0a1628;border-radius:6px;padding:6px 10px;font-size:12px;display:flex;justify-content:space-between;flex-wrap:wrap;">
                <span>🎯 预测: ${t.direction}</span>
                <span>📊 实际: ${t.result}</span>
                <span style="color:${correct ? '#4caf50' : '#f44336'};">${correct ? '✅ 命中' : '❌ 未中'}</span>
                ${t.actualScore ? `<span>比分: ${t.actualScore}</span>` : ''}
            </div>
        </div>`;
    }
    el.innerHTML = html;
}

