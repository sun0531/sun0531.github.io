function toggleTrack(matchId) {
    const match = allMatches.find(m => m.id === matchId);
    if (!match) return;
    const existing = trackedBets.find(t => t.matchId === matchId);
    if (existing) {
        trackedBets = trackedBets.filter(t => t.matchId !== matchId);
    } else {
        // 默认参数
        trackedBets.push({
            matchId: match.id,
            home: match.home_team,
            away: match.away_team,
            league: match.sport_title || '未知',
            time: match.commence_time,
            addedAt: new Date().toISOString(),
            homeGoals: 1.6,
            homeConceded: 1.2,
            awayGoals: 1.4,
            awayConceded: 1.3,
            h2h: '2胜1平2负',
            events: '',
            direction: '待定',
            amount: 0,
            odds: 0,
            result: 'pending',
            profit: 0,
            prediction: null
        });
    }
    saveData();
    renderMatches();
    updateTrackCount();
}

function updateTrackCount() {
