<script>
// ===================================================================
// 1. 核心配置
// ===================================================================
const API_KEY = 'f74ecb2f05a3b0263522a21119a9635a';
let allMatches = [];
let trackedBets = [];
let modelParams = {};
let currentTrackMatch = null;
let currentResultMatchId = null;

// ===================================================================
// 2. 数据存储
// ===================================================================
function loadData() {
    try {
        const data = localStorage.getItem('fb_v4_data');
        if (data) {
            const parsed = JSON.parse(data);
            trackedBets = parsed.trackedBets || [];
            modelParams = parsed.modelParams || getDefaultParams();
        } else {
            modelParams = getDefaultParams();
        }
    } catch(e) { trackedBets = []; modelParams = getDefaultParams(); }
}

function saveData() {
    try {
        localStorage.setItem('fb_v4_data', JSON.stringify({
            trackedBets: trackedBets,
            modelParams: modelParams
        }));
    } catch(e) {}
}

function getDefaultParams() {
    return {
        // 市场模型权重
        weight_market: 0.30,
        weight_poisson: 0.20,
        weight_form: 0.15,
        weight_h2h: 0.10,
        weight_injury: 0.10,
        weight_odds_velocity: 0.10,
        weight_euro_asia: 0.05,
        // 泊松参数
        home_advantage: 1.25,
        league_avg_goals: 1.35,
        // 学习参数
        learning_rate: 0.02,
        total_predictions: 0,
        total_hits: 0
    };
}

// ===================================================================
// 3. 预测引擎
// ===================================================================

// 3.1 去水概率
function calcProb(h, d, a) {
    if (h <= 0 || a <= 0) return { home: 0, draw: 0, away: 0 };
    const ih = 1/h, id = d > 0 ? 1/d : 0, ia = 1/a;
    const over = ih + id + ia;
    if (over === 0) return { home: 0, draw: 0, away: 0 };
    const vig = 1 / over;
    return {
        home: Math.round(ih * vig * 1000) / 1000,
        draw: Math.round(id * vig * 1000) / 1000,
        away: Math.round(ia * vig * 1000) / 1000
    };
}

// 3.2 市场离散度
function calcDispersion(odds) {
    // odds: [{home, draw, away}] 多公司赔率
    if (!odds || odds.length < 2) return { home: 0, draw: 0, away: 0 };
    const n = odds.length;
    const avg = { home: 0, draw: 0, away: 0 };
    for (const o of odds) {
        avg.home += o.home / n;
        avg.draw += o.draw / n;
        avg.away += o.away / n;
    }
    let varHome = 0, varDraw = 0, varAway = 0;
    for (const o of odds) {
        varHome += Math.pow(o.home - avg.home, 2) / n;
        varDraw += Math.pow(o.draw - avg.draw, 2) / n;
        varAway += Math.pow(o.away - avg.away, 2) / n;
    }
    const stdHome = Math.sqrt(varHome);
    const stdDraw = Math.sqrt(varDraw);
    const stdAway = Math.sqrt(varAway);
    // 离散度归一化：标准差/平均值 * 100
    const dispHome = avg.home > 0 ? (stdHome / avg.home) * 100 : 0;
    const dispDraw = avg.draw > 0 ? (stdDraw / avg.draw) * 100 : 0;
    const dispAway = avg.away > 0 ? (stdAway / avg.away) * 100 : 0;
    return { home: dispHome, draw: dispDraw, away: dispAway, avg: avg };
}

// 3.3 泊松进球模型
function poissonGoals(lambda, maxGoals) {
    // 计算泊松分布
    const probs = [];
    const e = Math.exp(-lambda);
    for (let k = 0; k <= maxGoals; k++) {
        let p = e;
        for (let i = 1; i <= k; i++) {
            p *= (lambda / i);
        }
        probs.push(p);
    }
    return probs;
}

function calcExpectedGoals(homeAttack, homeDefense, awayAttack, awayDefense, homeAdvantage, leagueAvg) {
    const homeXG = homeAttack * awayDefense * homeAdvantage * leagueAvg / 1.35;
    const awayXG = awayAttack * homeDefense * leagueAvg / 1.35;
    return { home: homeXG, away: awayXG };
}

// 3.4 比分矩阵
function calcScoreMatrix(lambdaHome, lambdaAway, maxGoals) {
    const homeProbs = poissonGoals(lambdaHome, maxGoals);
    const awayProbs = poissonGoals(lambdaAway, maxGoals);
    const matrix = [];
    for (let i = 0; i <= maxGoals; i++) {
        for (let j = 0; j <= maxGoals; j++) {
            matrix.push({
                home: i,
                away: j,
                prob: homeProbs[i] * awayProbs[j]
            });
        }
    }
    return matrix;
}

// 3.5 大小球概率
function calcOverUnder(matrix, threshold) {
    let over = 0, under = 0;
    for (const m of matrix) {
        const total = m.home + m.away;
        if (total > threshold) over += m.prob;
        else under += m.prob;
    }
    return { over: over, under: under };
}

// 3.6 双方进球概率
function calcBothScore(matrix) {
    let both = 0, notBoth = 0;
    for (const m of matrix) {
        if (m.home > 0 && m.away > 0) both += m.prob;
        else notBoth += m.prob;
    }
    return { both: both, notBoth: notBoth };
}

// 3.7 欧亚一致性检测
function checkEuroAsia(euroHome, asianHandicap) {
    // 欧赔主胜 1.80-2.00 区间对应亚盘 0.5球
    if (euroHome >= 1.70 && euroHome <= 2.10) {
        const theoretical = 0.5;
        const diff = Math.abs(asianHandicap - theoretical);
        if (diff < 0.1) return { consistent: true, signal: '欧亚一致' };
        else if (asianHandicap < theoretical) return { consistent: false, signal: '浅盘诱下' };
        else return { consistent: false, signal: '深盘诱上' };
    }
    return { consistent: true, signal: '区间外' };
}

// 3.8 赔率变化速度
function calcOddsVelocity(prev, curr, timeDiff) {
    if (!prev || !curr || timeDiff === 0) return { home: 0, draw: 0, away: 0 };
    return {
        home: (prev.home - curr.home) / timeDiff,
        draw: (prev.draw - curr.draw) / timeDiff,
        away: (prev.away - curr.away) / timeDiff
    };
}

// ===================================================================
// 4. 综合预测
// ===================================================================
function predictMatch(matchData, manualData) {
    // matchData: { home, away, odds: { home, draw, away }, bookmakers }
    // manualData: { homeGoals, homeConceded, awayGoals, awayConceded, h2h, events }
    
    const odds = matchData.odds;
    const prob = calcProb(odds.home, odds.draw, odds.away);
    
    // === 第一层：市场模型 ===
    // 去水概率
    const marketProb = prob;
    // 市场离散度（如果有多个bookmaker）
    let dispersion = { home: 0, draw: 0, away: 0 };
    if (matchData.bookmakers && matchData.bookmakers.length > 1) {
        const oddsList = matchData.bookmakers.map(b => {
            const mk = b.markets.find(m => m.key === 'h2h');
            if (!mk) return null;
            const outcomes = mk.outcomes;
            const h = outcomes.find(o => o.name === matchData.home)?.price || 0;
            const d = outcomes.find(o => o.name === 'Draw')?.price || 0;
            const a = outcomes.find(o => o.name === matchData.away)?.price || 0;
            return { home: h, draw: d, away: a };
        }).filter(o => o && o.home > 0);
        if (oddsList.length > 1) {
            dispersion = calcDispersion(oddsList);
        }
    }
    
    // 数据完整度评分
    let completeness = 0;
    if (odds.home > 0 && odds.draw > 0 && odds.away > 0) completeness += 30;
    if (matchData.bookmakers && matchData.bookmakers.length > 3) completeness += 20;
    if (manualData && manualData.homeGoals > 0) completeness += 15;
    if (manualData && manualData.h2h) completeness += 15;
    if (manualData && manualData.events) completeness += 10;
    completeness = Math.min(completeness, 100);
    
    // 市场模型方向
    const marketDir = prob.home > prob.away ? (prob.home > prob.draw ? '主胜' : '平局') : (prob.away > prob.draw ? '客胜' : '平局');
    const marketScore = Math.max(prob.home, prob.draw, prob.away);
    
    // === 第二层：进球模型 ===
    let homeXG = 1.4, awayXG = 1.2;
    if (manualData && manualData.homeGoals > 0) {
        const hAttack = manualData.homeGoals / 1.35;
        const hDefense = manualData.homeConceded / 1.35;
        const aAttack = manualData.awayGoals / 1.35;
        const aDefense = manualData.awayConceded / 1.35;
        const xg = calcExpectedGoals(hAttack, hDefense, aAttack, aDefense, modelParams.home_advantage, modelParams.league_avg_goals);
        homeXG = xg.home;
        awayXG = xg.away;
    }
    
    // 比分矩阵
    const maxGoals = 6;
    const matrix = calcScoreMatrix(homeXG, awayXG, maxGoals);
    
    // 大小球
    const overUnder25 = calcOverUnder(matrix, 2.5);
    const overUnder35 = calcOverUnder(matrix, 3.5);
    
    // 双方进球
    const bothScore = calcBothScore(matrix);
    
    // 最可能比分
    const sortedMatrix = matrix.sort((a, b) => b.prob - a.prob);
    const topScores = sortedMatrix.slice(0, 5);
    
    // 进球模型方向
    const totalXG = homeXG + awayXG;
    const goalsDir = totalXG >= 2.8 ? '大球倾向' : (totalXG >= 2.0 ? '2-3球' : '小球倾向');
    
    // === 综合输出 ===
    // 融合胜平负：市场模型50% + 泊松模型50%
    const poissonProbs = calcProb(1/homeXG, 1/(homeXG+awayXG), 1/awayXG);
    // 简化融合
    const fusedProb = {
        home: marketProb.home * 0.5 + poissonProbs.home * 0.5,
        draw: marketProb.draw * 0.5 + poissonProbs.draw * 0.5,
        away: marketProb.away * 0.5 + poissonProbs.away * 0.5
    };
    
    // 归一化
    const sum = fusedProb.home + fusedProb.draw + fusedProb.away;
    if (sum > 0) {
        fusedProb.home /= sum;
        fusedProb.draw /= sum;
        fusedProb.away /= sum;
    }
    
    // 首选/次选
    const sorted = Object.entries(fusedProb).sort((a, b) => b[1] - a[1]);
    const first = sorted[0];
    const second = sorted[1];
    const directionMap = { home: '主胜', draw: '平局', away: '客胜' };
    const primary = directionMap[first[0]] || '主胜';
    const secondary = directionMap[second[0]] || '平局';
    
    // ABC等级
    let grade = 'C';
    if (first[1] >= 0.45) grade = 'A';
    else if (first[1] >= 0.35) grade = 'B';
    else grade = 'C';
    
    // 信心评分
    const confidence = first[1];
    
    // 盘口冲突检测
    const euroAsia = checkEuroAsia(odds.home, 0.5); // 简化亚盘
    
    return {
        market: { prob: marketProb, direction: marketDir, score: marketScore, dispersion: dispersion, completeness: completeness },
        goals: { homeXG, awayXG, totalXG, over25: overUnder25.over, under25: overUnder25.under, bothScore: bothScore.both, topScores, direction: goalsDir },
        fused: { prob: fusedProb, primary, secondary, grade, confidence },
        euroAsia: euroAsia,
        timestamp: new Date().toISOString()
    };
}

