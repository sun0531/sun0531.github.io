            </div>
            <div class="teams">${m.home_team} <span class="vs">vs</span> ${m.away_team}</div>
            <div class="odds">
                <span class="win">主 ${odds.home.toFixed(2)}</span>
                ${odds.draw > 0 ? `<span class="draw">平 ${odds.draw.toFixed(2)}</span>` : ''}
                <span class="lose">客 ${odds.away.toFixed(2)}</span>
            </div>
            
            <div class="prediction-box">
                <div class="row">
                    <span class="label">第一层·市场模型</span>
                    <span class="value">${pred.market.direction} (${(pred.market.score*100).toFixed(1)}%)</span>
                    <span class="value" style="font-size:10px;color:#8899bb;">离散度 ${pred.market.dispersion.home.toFixed(1)}%</span>
                </div>
                <div class="row">
                    <span class="label">第二层·进球模型</span>
                    <span class="value blue">xG ${pred.goals.homeXG.toFixed(2)}-${pred.goals.awayXG.toFixed(2)}</span>
                    <span class="value">${pred.goals.direction}</span>
                </div>
                <div class="row">
                    <span class="label">综合输出</span>
                    <span class="value gold">${pred.fused.primary}</span>
                    <span class="value">次选 ${pred.fused.secondary}</span>
                    <span class="${gradeClass}">${pred.fused.grade}</span>
                </div>
                <div class="row">
                    <span class="label">参考比分</span>
                    <span class="value">${pred.goals.topScores.slice(0,3).map(s => `${s.home}-${s.away}`).join(' / ')}</span>
                </div>
                <div class="row">
                    <span class="label">大小球2.5</span>
                    <span class="value">大 ${(pred.goals.over25*100).toFixed(0)}% / 小 ${(pred.goals.under25*100).toFixed(0)}%</span>
