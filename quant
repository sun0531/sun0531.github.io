function openManualData(matchId) {
    const match = allMatches.find(m => m.id === matchId);
    if (!match) return;
    currentTrackMatch = match;
    const existing = trackedBets.find(t => t.matchId === matchId);
    document.getElementById('modalMatchInfo').textContent = `${match.home_team} vs ${match.away_team}`;
    document.getElementById('fHomeGoals').value = existing?.homeGoals || 1.6;
    document.getElementById('fHomeConceded').value = existing?.homeConceded || 1.2;
    document.getElementById('fAwayGoals').value = existing?.awayGoals || 1.4;
    document.getElementById('fAwayConceded').value = existing?.awayConceded || 1.3;
    document.getElementById('fH2H').value = existing?.h2h || '2胜1平2负';
    document.getElementById('fEvents').value = existing?.events || '';
    document.getElementById('dataModal').classList.add('show');
}

function closeModal() {
    document.getElementById('dataModal').classList.remove('show');
}

function saveManualData() {
    const match = currentTrackMatch;
    if (!match) return;
    const data = {
        homeGoals: parseFloat(document.getElementById('fHomeGoals').value) || 1.6,
        homeConceded: parseFloat(document.getElementById('fHomeConceded').value) || 1.2,
        awayGoals: parseFloat(document.getElementById('fAwayGoals').value) || 1.4,
        awayConceded: parseFloat(document.getElementById('fAwayConceded').value) || 1.3,
        h2h: document.getElementById('fH2H').value || '2胜1平2负',
        events: document.getElementById('fEvents').value || ''
    };
    const existing = trackedBets.find(t => t.matchId === match.id);
    if (existing) {
        Object.assign(existing, data);
        // 重新生成预测
        const matchData = { home: match.home_team, away: match.away_team, odds: getOddsForMatch(match), bookmakers: match.bookmakers };
        const pred = predictMatch(matchData, data);
        existing.prediction = JSON.stringify(pred);
        existing.direction = pred.fused.primary;
    } else {
        // 自动添加追踪
        trackedBets.push({
            matchId: match.id,
            home: match.home_team,
            away: match.away_team,
            league: match.sport_title || '未知',
            time: match.commence_time,
            addedAt: new Date().toISOString(),
            ...data,
            direction: '待定',
            amount: 0,
            odds: 0,
            result: 'pending',
            profit: 0,
            prediction: null
        });
    }
    saveData();
    closeModal();
    renderMatches();
    updateTrackCount();
}

function getOddsForMatch(match) {
    const bm = match.bookmakers.find(b => b.key === 'pinnacle') || match.bookmakers[0];
    const mk = bm?.markets?.find(k => k.key === 'h2h');
    if (!mk) return { home: 0, draw: 0, away: 0 };
    const outcomes = mk.outcomes;
    const home = outcomes.find(o => o.name === match.home_team);
    const away = outcomes.find(o => o.name === match.away_team);
    const draw = outcomes.find(o => o.name === 'Draw');
    return { home: home?.price || 0, draw: draw?.price || 0, away: away?.price || 0 };
}

