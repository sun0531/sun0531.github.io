<!doctype html><html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>China Quant Pilot V3.2</title><style>
:root{--bg:#06101d;--panel:#0d1d31;--line:#28425f;--text:#eef5ff;--muted:#98acc5;--blue:#3cabff;--green:#2ed6a2;--red:#ff667d;--gold:#ffca62}*{box-sizing:border-box}body{margin:0;background:linear-gradient(135deg,#05101d,#0b192c);color:var(--text);font:14px Arial,"Microsoft YaHei",sans-serif}header{display:flex;justify-content:space-between;padding:18px 24px;border-bottom:1px solid var(--line)}h1{margin:0}h1 b{color:var(--blue)}header p,.muted{color:var(--muted);margin:5px 0}.pill{display:inline-block;padding:7px 10px;border:1px solid var(--line);border-radius:20px;margin:3px}nav{position:sticky;top:0;z-index:3;display:flex;gap:6px;overflow:auto;padding:10px 20px;background:#071321ee}button{border:1px solid var(--line);border-radius:8px;background:#142a44;color:#fff;padding:8px 12px;cursor:pointer}.active,button:hover{border-color:var(--blue);background:#17436b}main{padding:18px 22px}.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.card{background:linear-gradient(145deg,#0c1b2e,#112640);border:1px solid var(--line);border-radius:12px;padding:15px}.hero{border:1px solid #3ad8a5;background:linear-gradient(145deg,#0b302b,#102a3b);box-shadow:0 0 22px #2ed6a222}.hero h3{margin:0 0 8px}.big{font-size:25px;font-weight:bold}.green{color:var(--green)}.red{color:var(--red)}.gold{color:var(--gold)}.notice{padding:12px;background:#18253b;border-left:3px solid var(--gold);margin:10px 0}.toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:10px 0}input,select{background:#081624;color:white;border:1px solid var(--line);padding:8px;border-radius:7px}.tablewrap{overflow:auto;max-height:68vh}table{width:100%;border-collapse:collapse;background:#0a192a}th,td{padding:9px;border-bottom:1px solid var(--line);white-space:nowrap;text-align:left}th{position:sticky;top:54px;background:#122840}.score{font-weight:bold;color:var(--green)}.tag{padding:4px 7px;border-radius:10px;background:#183951}.tag.a{background:#14523f;color:#8dffce}.tag.h{background:#533c14;color:#ffd98b}.tag.r{background:#4d1f2b;color:#ff9cab}.progress{height:7px;background:#1a3149;border-radius:5px;overflow:hidden}.progress i{display:block;height:100%;background:linear-gradient(90deg,var(--blue),var(--green))}@media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}header{display:block}}@media(max-width:520px){.grid{grid-template-columns:1fr}main{padding:10px}}
</style></head><body><header><div><h1>China Quant Pilot <b>V3.2</b></h1><p>击球区间 · 可介入性 · 风险收益比 · 自动刷新</p></div><div><span id="status" class="pill gold">连接中</span><span id="countdown" class="pill">--</span><span id="clock" class="pill"></span></div></header><nav id="nav"></nav><main id="app"></main><script>
const tabs=['驾驶舱','A股击球区','ETF轮动','可转债雷达','模拟交易','数据诊断'];let cur=0,lastUpdate=null,timer=null,remaining=60;let cfg=JSON.parse(localStorage.getItem('cqp32cfg')||'{"on":true,"seconds":60}');let data={stocks:[],etfs:[],bonds:[]};let store=JSON.parse(localStorage.getItem('cqp32store')||'{"cash":100000,"positions":[]}');const $=s=>document.querySelector(s);
function jsonp(url,timeout=15000){return new Promise((resolve,reject)=>{let cb='cqp_'+Date.now()+'_'+Math.random().toString(36).slice(2),s=document.createElement('script'),t=setTimeout(()=>done(new Error('请求超时')),timeout);function done(e,v){clearTimeout(t);delete window[cb];s.remove();e?reject(e):resolve(v)}window[cb]=v=>done(null,v);s.onerror=()=>done(new Error('数据源拒绝浏览器请求'));s.src=url.replace('{callback}',cb);document.head.appendChild(s)})}
const EM='https://push2.eastmoney.com/api/qt/clist/get?cb={callback}&pn=1&pz=300&po=1&np=1&fltt=2&invt=2&fid=f6&fields=f12,f14,f2,f3,f4,f5,f6,f7,f8,f10,f15,f16,f17,f18,f22,f24,f25&fs=';
function calc(x,type){let p=+x.f2||0,chg=+x.f3||0,turn=+x.f8||0,vr=+x.f10||0,speed=+x.f22||0,high=+x.f15||p,low=+x.f16||p,open=+x.f17||p,prev=+x.f18||p;let limit=(String(x.f12).startsWith('30')||String(x.f12).startsWith('68'))?20:10;let nearLimit=chg>=limit-0.5,overheat=nearLimit||chg>=7||speed>=1.5;let strength=Math.round(Math.max(0,Math.min(100,50+chg*3+Math.min(turn,15)*1.2+Math.min(vr,4)*5+speed*5)));let intradayRange=Math.max(high-low,p*.01),support=Math.max(low,p-intradayRange*.35),trigger=Math.max(p,high*.998);let stop=support-intradayRange*.25,risk=Math.max(p-stop,p*.015);let target1=p+risk*1.6,target2=p+risk*2.3,rr=(target1-p)/risk;let entry=Math.round(Math.max(0,Math.min(100,78-Math.abs(chg-2.8)*7-Math.max(0,speed-.7)*12+Math.min(vr,2)*5-Math.max(0,turn-12)*2)));let riskScore=Math.round(Math.max(0,Math.min(100,20+Math.max(0,chg-5)*10+Math.max(0,speed-1)*15+Math.max(0,turn-15)*2)));let inZone=p>=support&&p<=support+risk*.7&&!overheat&&entry>=72&&rr>=1.5;let nearZone=!inZone&&!overheat&&entry>=65&&p<support+risk*1.25;let status=nearLimit?'涨停/临近涨停，不追':overheat?'强势但过热':inZone?'进入击球区间':nearZone?'接近击球区间':'普通观察';let grade=nearLimit||overheat?'H':inZone?'A':nearZone?'B':riskScore>=70?'R':'C';let priority=Math.round(entry*.4+strength*.25+Math.min(rr/2.5*100,100)*.2+(100-riskScore)*.15-(overheat?50:0));return {代码:x.f12,名称:x.f14,现价:p,涨跌幅:chg,强度:strength,可介入:entry,风险:riskScore,风险收益比:+rr.toFixed(2),击球区间:`${support.toFixed(2)}-${(support+risk*.7).toFixed(2)}`,突破价:+trigger.toFixed(2),失效价:+stop.toFixed(2),目标一:`${target1.toFixed(2)}`,目标二:`${target2.toFixed(2)}`,状态:status,等级:grade,机会优先级:priority,类型:type,更新时间:new Date().toLocaleTimeString()}}
function norm(j,type){return (j?.data?.diff||[]).map(x=>calc(x,type)).filter(x=>x.现价>0)}
async function loadAll(manual=false){setStatus('更新中','gold');try{let [s,e,b]=await Promise.all([jsonp(EM+encodeURIComponent('m:0+t:6,m:0+t:80,m:1+t:2,m:1+t:23')),jsonp(EM+encodeURIComponent('b:MK0021,b:MK0022,b:MK0023,b:MK0024')),jsonp(EM+encodeURIComponent('b:MK0354'))]);data.stocks=norm(s,'股票').filter(x=>!String(x.名称).match(/ST|退/)).sort((a,b)=>b.机会优先级-a.机会优先级);data.etfs=norm(e,'ETF').sort((a,b)=>b.机会优先级-a.机会优先级);data.bonds=norm(b,'可转债').sort((a,b)=>b.机会优先级-a.机会优先级);lastUpdate=new Date();remaining=cfg.seconds;setStatus('行情已更新','green');render(cur)}catch(e){setStatus('连接失败','red');if(manual)alert('行情更新失败：'+e.message)}}
function setStatus(t,c){$('#status').textContent=t;$('#status').className='pill '+c}function save(){localStorage.setItem('cqp32store',JSON.stringify(store));localStorage.setItem('cqp32cfg',JSON.stringify(cfg))}function fmt(v){if(typeof v==='number'&&Math.abs(v)>1e8)return(v/1e8).toFixed(2)+'亿';return v??'--'}
function table(rows,action=true){if(!rows.length)return '<div class="notice">当前没有符合条件的标的。</div>';let keys=['等级','代码','名称','现价','涨跌幅','强度','可介入','风险','风险收益比','击球区间','突破价','失效价','目标一','状态'];return `<div class="tablewrap"><table><thead><tr>${keys.map(k=>`<th>${k}</th>`).join('')}${action?'<th>操作</th>':''}</tr></thead><tbody>${rows.map(r=>`<tr>${keys.map(k=>`<td class="${k==='可介入'?'score':''}">${k==='等级'?`<span class="tag ${r[k].toLowerCase()}">${r[k]}</span>`:fmt(r[k])}</td>`).join('')}${action?`<td><button onclick='buy(${JSON.stringify(r)})'>模拟买入</button></td>`:''}</tr>`).join('')}</tbody></table></div>`}
function heroCards(rows){if(!rows.length)return '<div class="notice">目前没有同时满足“趋势、可介入性、风险收益比与不过热”条件的强烈推荐。空仓等待也是策略的一部分。</div>';return `<div class="grid">${rows.slice(0,5).map(r=>`<div class="card hero"><h3><span class="tag a">A级</span> ${r.名称}</h3><div class="big green">${r.现价}</div><p>击球区间：<b>${r.击球区间}</b></p><p>失效价：<span class="red">${r.失效价}</span>　目标：${r.目标一}</p><p>强度 ${r.强度}｜可介入 ${r.可介入}｜风险 ${r.风险}</p><p>风险收益比 ${r.风险收益比}｜优先级 ${r.机会优先级}</p><div class="progress"><i style="width:${r.机会优先级}%"></i></div><p class="muted">条件满足后仍需人工确认量价与板块同步。</p><button onclick='buy(${JSON.stringify(r)})'>模拟买入</button></div>`).join('')}</div>`}
function nav(){$('#nav').innerHTML=tabs.map((x,i)=>`<button onclick="render(${i})">${x}</button>`).join('')}function render(i=0){cur=i;[...document.querySelectorAll('nav button')].forEach((b,n)=>b.classList.toggle('active',n===i));let a=$('#app'),strong=data.stocks.filter(x=>x.等级==='A'&&x.机会优先级>=70),near=data.stocks.filter(x=>x.等级==='B'),hot=data.stocks.filter(x=>x.等级==='H');if(i===0)a.innerHTML=`<h2>交易驾驶舱</h2><div class="grid"><div class="card"><div class="muted">进入击球区</div><div class="big green">${strong.length}</div></div><div class="card"><div class="muted">接近击球区</div><div class="big">${near.length}</div></div><div class="card"><div class="muted">强势过热</div><div class="big gold">${hot.length}</div></div><div class="card"><div class="muted">模拟现金</div><div class="big">¥${store.cash.toFixed(0)}</div></div></div><h2>强烈推荐｜已进入击球区间</h2>${heroCards(strong)}<div class="notice">强烈推荐表示策略条件匹配度较高，不是保证上涨。涨停及临近涨停股票不会进入此区域。</div>`;if(i===1)a.innerHTML=`<h2>A股击球区</h2>${controls()}<h2>① 强烈推荐｜已进入击球区间</h2>${heroCards(strong)}<h2>② 接近击球区间</h2>${table(near.slice(0,40))}<h2>③ 强势但过热｜当日不追</h2>${table(hot.slice(0,40),false)}<h2>④ 普通观察</h2>${table(data.stocks.filter(x=>x.等级==='C').slice(0,50))}`;if(i===2)a.innerHTML='<h2>ETF轮动</h2>'+controls()+table(data.etfs.slice(0,80));if(i===3)a.innerHTML='<h2>可转债雷达</h2>'+controls()+'<div class="notice">转债点位仅按盘中波动估算，交易前必须核查强赎、最后交易日、剩余规模及溢价率。</div>'+table(data.bonds.slice(0,80));if(i===4)a.innerHTML=positions();if(i===5)a.innerHTML=diagnostic()}
function controls(){return `<div class="toolbar"><button onclick="loadAll(true)">立即刷新</button><label><input type="checkbox" ${cfg.on?'checked':''} onchange="cfg.on=this.checked;save()"> 自动刷新</label><select onchange="cfg.seconds=+this.value;remaining=cfg.seconds;save()"><option value="30" ${cfg.seconds===30?'selected':''}>30秒</option><option value="60" ${cfg.seconds===60?'selected':''}>60秒</option><option value="120" ${cfg.seconds===120?'selected':''}>2分钟</option><option value="300" ${cfg.seconds===300?'selected':''}>5分钟</option></select><span class="pill">最后更新：${lastUpdate?lastUpdate.toLocaleTimeString():'--'}</span></div>`}
function buy(r){if(r.等级==='H')return alert('该标的处于过热/涨停观察状态，策略不建议追涨。');let q=+(prompt(`模拟买入 ${r.名称}\n现价 ${r.现价}\n击球区间 ${r.击球区间}\n失效价 ${r.失效价}\n请输入数量`,100)||0);if(!q)return;let cost=r.现价*q;if(cost>store.cash)return alert('模拟现金不足');store.cash-=cost;store.positions.push({代码:r.代码,名称:r.名称,成本价:r.现价,数量:q,失效价:r.失效价,目标:r.目标一,时间:new Date().toLocaleString()});save();alert('已记录模拟买入')}
function positions(){return `<h2>模拟交易</h2><div class="card"><div class="muted">可用现金</div><div class="big">¥${store.cash.toFixed(2)}</div></div>${store.positions.length?`<div class="tablewrap"><table><tr><th>代码</th><th>名称</th><th>成本</th><th>数量</th><th>失效价</th><th>目标</th><th>时间</th></tr>${store.positions.map(x=>`<tr>${Object.values(x).map(v=>`<td>${v}</td>`).join('')}</tr>`).join('')}</table></div>`:'<div class="notice">暂无模拟持仓。</div>'}`}
function diagnostic(){return `<h2>数据诊断</h2>${controls()}<div class="card"><p>运行方式：纯HTML网页</p><p>安装Python：不需要</p><p>云端部署：不需要</p><p>接口模式：浏览器JSONP直连公开行情页</p><p>最后成功更新：${lastUpdate?lastUpdate.toLocaleString():'暂无'}</p><p>A股/ETF/转债：${data.stocks.length}/${data.etfs.length}/${data.bonds.length}</p></div><div class="notice">点位基于当前快照和当日高低波动估算，缺少完整日线数据库时只能作为初筛。若上游停止JSONP，纯网页无法绕过限制。</div>`}
setInterval(()=>{$('#clock').textContent=new Date().toLocaleString();if(cfg.on){remaining--;if(remaining<=0){remaining=cfg.seconds;loadAll()}$('#countdown').textContent='下次刷新 '+remaining+'秒'}else $('#countdown').textContent='自动刷新已关闭'},1000);nav();render();loadAll();
</script></body></html>
