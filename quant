async function fetchData() {
    const el = document.getElementById('matchList');
    el.innerHTML = '<div class="loading">⏳ 获取数据...</div>';
    try {
        const url = `https://api.the-odds-api.com/v4/sports/soccer/odds/?apiKey=${API_KEY}&regions=eu&markets=h2h&dateFormat=iso`;
        const resp = await fetch(url);
        if (!resp.ok) throw new Error('API请求失败');
        const data = await resp.json();
        allMatches = data.filter(m => m.bookmakers && m.bookmakers.length);
        renderMatches();
        updateTrackCount();
    } catch(e) {
        el.innerHTML = `<div class="empty">❌ 加载失败：${e.message}</div>`;
    }
}

