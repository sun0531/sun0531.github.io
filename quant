    const totalAmount = trackedBets.reduce((sum, t) => sum + (t.amount || 0), 0);
    const totalReturn = trackedBets.reduce((sum, t) => sum + ((t.profit || 0) + (t.amount || 0)), 0);
    const totalProfit = trackedBets.reduce((sum, t) => sum + (t.profit || 0), 0);
    const hitRate = settled.length > 0 ? Math.round((wins.length / settled.length) * 100) : 0;
    
    document.getElementById('sTotal').textContent = total;
    document.getElementById('sHit').textContent = wins.length;
    document.getElementById('sMiss').textContent = losses.length;
    document.getElementById('sRate').textContent = hitRate + '%';
    document.getElementById('pTotal').textContent = totalAmount.toFixed(0);
    document.getElementById('pReturn').textContent = totalReturn.toFixed(0);
