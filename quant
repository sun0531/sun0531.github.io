function openResultModal(matchId) {
    const match = allMatches.find(m => m.id === matchId);
    if (!match) return;
    currentResultMatchId = matchId;
    document.getElementById('resultMatchInfo').textContent = `${match.home_team} vs ${match.away_team}`;
    document.getElementById('actualResult').value = 'home';
    document.getElementById('actualScore').value = '1-0';
    document.getElementById('resultModal').classList.add('show');
}

function closeResultModal() {
    document.getElementById('resultModal').classList.remove('show');
}

function saveResult() {
    const matchId = currentResultMatchId;
    const match = allMatches.find(m => m.id === matchId);
    if (!match) return;
    const result = document.getElementById('actualResult').value;
    const score = document.getElementById('actualScore').value;
    const existing = trackedBets.find(t => t.matchId === matchId);
    if (existing) {
        existing.result = result;
        existing.actualScore = score;
        // 计算盈亏（简化）
        if (existing.direction === '主胜' && result === 'home') existing.profit = existing.amount * (existing.odds - 1);
        else if (existing.direction === '客胜' && result === 'away') existing.profit = existing.amount * (existing.odds - 1);
        else if (existing.direction === '平局' && result === 'draw') existing.profit = existing.amount * (existing.odds - 1);
        else if (result === 'draw') existing.profit = 0;
        else existing.profit = -existing.amount;
        // 更新学习统计
        modelParams.total_predictions += 1;
        if ((existing.direction === '主胜' && result === 'home') ||
            (existing.direction === '客胜' && result === 'away') ||
            (existing.direction === '平局' && result === 'draw')) {
            modelParams.total_hits += 1;
        }
        // 自我学习：调整权重
        adaptWeights(existing);
        saveData();
    }
    closeResultModal();
    renderMatches();
    updateTrackCount();
    updateStats();
    renderLearnPanel();
}

// ===================================================================
// 9. 自我学习引擎
// ===================================================================
function adaptWeights(record) {
    // 简单自适应：如果预测正确，增加该维度权重；如果错误，降低
    const isCorrect = (record.direction === '主胜' && record.result === 'home') ||
                      (record.direction === '客胜' && record.result === 'away') ||
                      (record.direction === '平局' && record.result === 'draw');
    const lr = modelParams.learning_rate || 0.02;
    if (isCorrect) {
        // 正确时略微增加市场模型权重
        modelParams.weight_market = Math.min(modelParams.weight_market + lr * 0.5, 0.50);
        modelParams.weight_poisson = Math.min(modelParams.weight_poisson + lr * 0.3, 0.30);
    } else {
        // 错误时略微降低
        modelParams.weight_market = Math.max(modelParams.weight_market - lr * 0.3, 0.15);
        modelParams.weight_poisson = Math.max(modelParams.weight_poisson - lr * 0.2, 0.10);
    }
}

